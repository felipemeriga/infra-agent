GUARDIAN_URL=http://server-guardian:3000
GUARDIAN_API_KEY=your-internal-api-key
INTERNAL_API_KEY=your-mcp-auth-key
MCP_PORT=8002
COMPOSE_DIR=/path/to/your/compose/files
PROTECTED_SERVICES=server-guardian

# Monitoring
MONITOR_INTERVAL=60
NOTIFICATION_COOLDOWN=900
MEMORY_THRESHOLD_PCT=90
MAX_RESTARTS_WINDOW=600
MAX_RESTARTS_COUNT=3
STRIKE_THRESHOLD=2

# Production Hardening
SUPABASE_DB_URL=
CIRCUIT_BREAKER_FAILURES=3
CIRCUIT_BREAKER_TIMEOUT=60
SHUTDOWN_TIMEOUT=30

# LLM Fallback (optional — direct LLM when server-guardian is down)
# Supported providers: anthropic, openai, google
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
